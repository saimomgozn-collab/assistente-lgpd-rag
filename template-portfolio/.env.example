# Copie para .env e preencha. NUNCA commitar .env.
# Escolha 1 provider (default: Gemini Free Tier — ver CURRICULUM.md §Setup de API e Custo)

# Opção A — Gemini Free Tier (default)
GEMINI_API_KEY=AIza_substitua_aqui

# Opção B — OpenAI ($5 free credit)
# OPENAI_API_KEY=sk-substitua

# Opção C — Anthropic ($5 free credit, expira 14d após claim)
# ANTHROPIC_API_KEY=sk-ant-substitua

# Modelos (descomente conforme provider)
LLM_MODEL=gemini-2.5-flash-lite
# LLM_MODEL=gpt-4o-mini
# LLM_MODEL=claude-haiku-4.5
EMBED_MODEL=gemini-embedding-001

# Opcional — observabilidade (descomente se for usar Langfuse)
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com
